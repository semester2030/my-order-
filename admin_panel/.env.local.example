# للتطوير على localhost: لا تضع NEXT_PUBLIC_API_URL على :3001 — يسبب CORS و"Failed to fetch".
# الكود يتجاهل 3001 تلقائياً على localhost ويستخدم `/api/...` → next.config rewrites → Nest.
#
# للإنتاج (لوحة على نطاق مختلف عن الـ API): ضع رابط الـ API الكامل
# NEXT_PUBLIC_API_URL=https://my-order.onrender.com

# هدف البروكسي المحلي (اختياري)
# API_PROXY_TARGET=http://localhost:3001
