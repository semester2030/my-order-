# --- مهم جداً إذا شغّلت الأدمن على localhost والتطبيق يضرب Render ---
# ضع رابط أصل الباك اند (بدون /api في النهاية). عندها طلبات الأدمن تذهب لنفس قاعدة بيانات الإنتاج.
# NEXT_PUBLIC_API_URL=https://my-order.onrender.com
#
# بدون السطر أعلاه: المتصفح يستخدم `/api` → next.config يوجّه لـ API_PROXY_TARGET (افتراضي localhost:3001)
# ولن تظهر تسجيلات المزوّنين القادمة من Render في «طلبات التسجيل».
#
# لا تضع هنا http://localhost:3001 — الكود يتجاهله على localhost ويستخدم البروكسي (تفادي CORS).

# هدف البروكسي عندما لا يوجد NEXT_PUBLIC_API_URL بعيد (اختياري)
# API_PROXY_TARGET=http://localhost:3001
