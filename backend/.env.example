# نسخ إلى .env وعدّل القيم. مسار الاختبار التجريبي: PAYMENT_PROVIDER=mock + PAYOUT_PROVIDER=mock

NODE_ENV=development

# === دفع العملاء (PSP) ===
# mock = جلسات وهمية + webhook أو إكمال تجريبي من لوحة الإدارة (غير production فقط)
# أي قيمة أخرى: يُحمَّل NotImplementedPaymentGateway — أضف محوّلاً حقيقياً في payments.module.ts
PAYMENT_PROVIDER=mock

# سر توقيع POST /api/payments/webhook (HMAC body — انظر payment-webhook-signature.ts)
PAYMENT_WEBHOOK_SECRET=change_me_min_8_chars

# تطوير: قبول webhook بدون توقيع إذا كان السر قصيراً (لا تستخدم في الإنتاج)
PAYMENT_DEV_ALLOW_UNSIGNED_WEBHOOK=true

# تطوير: السماح للعميل بـ POST /api/payments/confirm بعد تحقق وهمي (تطبيق العميل)
PAYMENT_DEV_ALLOW_CLIENT_CONFIRM_MOCK=true

# === تحويل مستحقات مقدّمي الخدمة ===
# mock = إكمال فوري في جدول payout_requests
# أي قيمة أخرى: NotImplementedPayoutGateway — أضف محوّلاً في payouts.module.ts
PAYOUT_PROVIDER=mock

# === حصة المزود من طبخ منزلي (اختياري) ===
# HOME_COOKING_VENDOR_SHARE_PERCENT=100
